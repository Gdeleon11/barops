generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  OWNER
  ADMIN
  MANAGER
  WAITER
  BARTENDER
  KITCHEN
  CASHIER
}

enum TableStatus {
  FREE
  OCCUPIED
  RESERVED
  CLEANING
}

enum OrderStatus {
  OPEN
  SENT
  PREPARING
  READY
  SERVED
  PAID
  CANCELLED
}

enum ReservationStatus {
  PENDING
  CONFIRMED
  SEATED
  CANCELLED
  NO_SHOW
}

model Tenant {
  id        String   @id @default(cuid())
  name      String
  plan      String   @default("PRO")
  createdAt DateTime @default(now())
  branches  Branch[]
  users     User[]
}

model Branch {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name      String
  address   String?
  timezone  String   @default("America/Mexico_City")
  createdAt DateTime @default(now())

  users        User[]
  products     Product[]
  categories   Category[]
  inventory    InventoryItem[]
  tables       RestaurantTable[]
  customers    Customer[]
  reservations Reservation[]
  orders       Order[]
  shifts       Shift[]
}

model User {
  id           String   @id @default(cuid())
  tenantId     String
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branchId     String?
  branch       Branch?  @relation(fields: [branchId], references: [id])
  name         String
  email        String   @unique
  passwordHash String
  role         Role     @default(WAITER)
  active       Boolean  @default(true)
  avatarUrl    String?
  createdAt    DateTime @default(now())

  orders Order[]
  shifts Shift[]
}

model Category {
  id       String    @id @default(cuid())
  branchId String
  branch   Branch    @relation(fields: [branchId], references: [id], onDelete: Cascade)
  name     String
  color    String    @default("#4d8eff")
  products Product[]
}

model Product {
  id         String   @id @default(cuid())
  branchId   String
  branch     Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)
  categoryId String?
  category   Category? @relation(fields: [categoryId], references: [id])
  name       String
  sku        String?
  price      Float
  cost       Float    @default(0)
  imageUrl   String?
  active     Boolean  @default(true)
  createdAt  DateTime @default(now())
  orderItems OrderItem[]
}

model InventoryItem {
  id        String   @id @default(cuid())
  branchId  String
  branch    Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)
  name      String
  unit      String   @default("unit")
  stock     Float    @default(0)
  parLevel  Float    @default(0)
  cost      Float    @default(0)
  supplier  String?
  updatedAt DateTime @updatedAt
}

model RestaurantTable {
  id        String      @id @default(cuid())
  branchId  String
  branch    Branch      @relation(fields: [branchId], references: [id], onDelete: Cascade)
  name      String
  seats     Int         @default(4)
  zone      String      @default("Salón")
  status    TableStatus @default(FREE)
  posX      Int         @default(0)
  posY      Int         @default(0)
  orders    Order[]
  reservations Reservation[]
}

model Customer {
  id         String   @id @default(cuid())
  branchId   String
  branch     Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)
  name       String
  phone      String?
  email      String?
  notes      String?
  loyaltyPts Int      @default(0)
  visits     Int      @default(0)
  totalSpent Float    @default(0)
  vip        Boolean  @default(false)
  createdAt  DateTime @default(now())
  reservations Reservation[]
  orders       Order[]
}

model Reservation {
  id         String   @id @default(cuid())
  branchId   String
  branch     Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)
  customerId String?
  customer   Customer? @relation(fields: [customerId], references: [id])
  tableId    String?
  table      RestaurantTable? @relation(fields: [tableId], references: [id])
  guestName  String
  partySize  Int      @default(2)
  dateTime   DateTime
  status     ReservationStatus @default(PENDING)
  notes      String?
  createdAt  DateTime @default(now())
}

model Order {
  id         String   @id @default(cuid())
  branchId   String
  branch     Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)
  tableId    String?
  table      RestaurantTable? @relation(fields: [tableId], references: [id])
  waiterId   String?
  waiter     User?    @relation(fields: [waiterId], references: [id])
  customerId String?
  customer   Customer? @relation(fields: [customerId], references: [id])
  number     Int
  status     OrderStatus @default(OPEN)
  subtotal   Float    @default(0)
  tax        Float    @default(0)
  tip        Float    @default(0)
  total      Float    @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  items      OrderItem[]
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id])
  name      String
  qty       Int     @default(1)
  price     Float
  status    String  @default("PENDING") // PENDING | PREPARING | READY | SERVED
  notes     String?
}

model Shift {
  id         String    @id @default(cuid())
  branchId   String
  branch     Branch    @relation(fields: [branchId], references: [id], onDelete: Cascade)
  userId     String
  user       User      @relation(fields: [userId], references: [id])
  openedAt   DateTime  @default(now())
  closedAt   DateTime?
  openingCash Float    @default(0)
  closingCash Float?
  salesTotal  Float    @default(0)
  notes       String?
}

// ---- Extended operational models (scalar FKs to keep it simple) ----

model WaitlistEntry {
  id         String   @id @default(cuid())
  branchId   String
  name       String
  partySize  Int      @default(2)
  phone      String?
  quotedWait Int      @default(15)
  status     String   @default("WAITING") // WAITING | SEATED | CANCELLED
  createdAt  DateTime @default(now())
}

model Supplier {
  id       String  @id @default(cuid())
  branchId String
  name     String
  contact  String?
  phone    String?
  email    String?
  category String?
}

model PurchaseOrder {
  id           String         @id @default(cuid())
  branchId     String
  supplierName String
  number       Int
  status       String         @default("DRAFT") // DRAFT | SENT | RECEIVED
  total        Float          @default(0)
  createdAt    DateTime       @default(now())
  items        PurchaseItem[]
}

model PurchaseItem {
  id              String        @id @default(cuid())
  purchaseOrderId String
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  name            String
  qty             Float         @default(1)
  unit            String        @default("unidad")
  cost            Float         @default(0)
}

model Recipe {
  id        String       @id @default(cuid())
  branchId  String
  name      String
  category  String?
  yield     String?
  salePrice Float        @default(0)
  createdAt DateTime     @default(now())
  items     RecipeItem[]
}

model RecipeItem {
  id         String @id @default(cuid())
  recipeId   String
  recipe     Recipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  ingredient String
  qty        Float  @default(0)
  unit       String @default("ml")
  cost       Float  @default(0)
}

model Device {
  id        String   @id @default(cuid())
  branchId  String
  name      String
  type      String   @default("POS") // POS | KDS | PRINTER | ROUTER | AP | TABLET
  ip        String?
  status    String   @default("ONLINE") // ONLINE | OFFLINE | WARNING
  firmware  String   @default("1.0.0")
  latencyMs Int      @default(0)
  uptime    Float    @default(100)
  lastSeen  DateTime @default(now())
}

model MaintenanceTask {
  id         String   @id @default(cuid())
  branchId   String
  deviceName String
  task       String
  dueDate    DateTime
  status     String   @default("PENDING") // PENDING | DONE | OVERDUE
  assignee   String?
}

model AuditLog {
  id        String   @id @default(cuid())
  branchId  String
  actor     String
  action    String
  target    String?
  severity  String   @default("INFO") // INFO | WARNING | CRITICAL
  detail    String?
  createdAt DateTime @default(now())
}

model Alert {
  id           String   @id @default(cuid())
  branchId     String
  title        String
  message      String
  level        String   @default("INFO") // INFO | WARNING | CRITICAL
  acknowledged Boolean  @default(false)
  createdAt    DateTime @default(now())
}

model Campaign {
  id        String   @id @default(cuid())
  branchId  String
  name      String
  channel   String   @default("WhatsApp")
  audience  String   @default("Todos")
  sent      Int      @default(0)
  delivered Int      @default(0)
  opened    Int      @default(0)
  status    String   @default("DRAFT") // DRAFT | SENT | SCHEDULED
  createdAt DateTime @default(now())
}

model PriceRule {
  id           String  @id @default(cuid())
  branchId     String
  name         String
  categoryName String?
  discountPct  Float   @default(0)
  startHour    Int     @default(17)
  endHour      Int     @default(20)
  days         String  @default("L-V")
  active       Boolean @default(true)
}

model Invoice {
  id        String   @id @default(cuid())
  tenantId  String
  number    String
  amount    Float
  status    String   @default("DUE") // PAID | DUE
  period    String
  createdAt DateTime @default(now())
}
