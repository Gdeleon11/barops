generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  OWNER
  ADMIN
  MANAGER
  WAITER
  BARTENDER
  KITCHEN
  CASHIER
}

enum TableStatus {
  FREE
  OCCUPIED
  RESERVED
  CLEANING
}

enum OrderStatus {
  OPEN
  SENT
  PREPARING
  READY
  SERVED
  PAID
  CANCELLED
}

enum ReservationStatus {
  PENDING
  CONFIRMED
  SEATED
  CANCELLED
  NO_SHOW
}

model Tenant {
  id        String   @id @default(cuid())
  name      String
  plan      String   @default("PRO")
  createdAt DateTime @default(now())
  branches  Branch[]
  users     User[]
}

model Branch {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name      String
  address   String?
  timezone  String   @default("America/Mexico_City")
  createdAt DateTime @default(now())

  users        User[]
  products     Product[]
  categories   Category[]
  inventory    InventoryItem[]
  tables       RestaurantTable[]
  customers    Customer[]
  reservations Reservation[]
  orders       Order[]
  shifts       Shift[]
}

model User {
  id           String   @id @default(cuid())
  tenantId     String
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branchId     String?
  branch       Branch?  @relation(fields: [branchId], references: [id])
  name         String
  email        String   @unique
  passwordHash String
  role         Role     @default(WAITER)
  active       Boolean  @default(true)
  avatarUrl    String?
  createdAt    DateTime @default(now())

  orders Order[]
  shifts Shift[]
}

model Category {
  id       String    @id @default(cuid())
  branchId String
  branch   Branch    @relation(fields: [branchId], references: [id], onDelete: Cascade)
  name     String
  color    String    @default("#4d8eff")
  products Product[]
}

model Product {
  id         String   @id @default(cuid())
  branchId   String
  branch     Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)
  categoryId String?
  category   Category? @relation(fields: [categoryId], references: [id])
  name       String
  sku        String?
  price      Float
  cost       Float    @default(0)
  imageUrl   String?
  active     Boolean  @default(true)
  createdAt  DateTime @default(now())
  orderItems OrderItem[]
}

model InventoryItem {
  id        String   @id @default(cuid())
  branchId  String
  branch    Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)
  name      String
  unit      String   @default("unit")
  stock     Float    @default(0)
  parLevel  Float    @default(0)
  cost      Float    @default(0)
  supplier  String?
  updatedAt DateTime @updatedAt
}

model RestaurantTable {
  id        String      @id @default(cuid())
  branchId  String
  branch    Branch      @relation(fields: [branchId], references: [id], onDelete: Cascade)
  name      String
  seats     Int         @default(4)
  zone      String      @default("Salón")
  status    TableStatus @default(FREE)
  posX      Int         @default(0)
  posY      Int         @default(0)
  orders    Order[]
  reservations Reservation[]
}

model Customer {
  id         String   @id @default(cuid())
  branchId   String
  branch     Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)
  name       String
  phone      String?
  email      String?
  notes      String?
  loyaltyPts Int      @default(0)
  visits     Int      @default(0)
  totalSpent Float    @default(0)
  vip        Boolean  @default(false)
  createdAt  DateTime @default(now())
  reservations Reservation[]
  orders       Order[]
}

model Reservation {
  id         String   @id @default(cuid())
  branchId   String
  branch     Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)
  customerId String?
  customer   Customer? @relation(fields: [customerId], references: [id])
  tableId    String?
  table      RestaurantTable? @relation(fields: [tableId], references: [id])
  guestName  String
  partySize  Int      @default(2)
  dateTime   DateTime
  status     ReservationStatus @default(PENDING)
  notes      String?
  createdAt  DateTime @default(now())
}

model Order {
  id         String   @id @default(cuid())
  branchId   String
  branch     Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)
  tableId    String?
  table      RestaurantTable? @relation(fields: [tableId], references: [id])
  waiterId   String?
  waiter     User?    @relation(fields: [waiterId], references: [id])
  customerId String?
  customer   Customer? @relation(fields: [customerId], references: [id])
  number     Int
  status     OrderStatus @default(OPEN)
  subtotal   Float    @default(0)
  tax        Float    @default(0)
  tip        Float    @default(0)
  total      Float    @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  items      OrderItem[]
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id])
  name      String
  qty       Int     @default(1)
  price     Float
  notes     String?
}

model Shift {
  id         String    @id @default(cuid())
  branchId   String
  branch     Branch    @relation(fields: [branchId], references: [id], onDelete: Cascade)
  userId     String
  user       User      @relation(fields: [userId], references: [id])
  openedAt   DateTime  @default(now())
  closedAt   DateTime?
  openingCash Float    @default(0)
  closingCash Float?
  salesTotal  Float    @default(0)
  notes       String?
}
